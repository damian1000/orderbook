orderbook.damianhoward.com {
	encode zstd gzip
	# Baseline hardening on every response. frame-ancestors is 'self', not 'none', because the
	# trading desk frames this front end through its own gateway origin (?embed=1).
	header {
		Strict-Transport-Security "max-age=31536000"
		X-Content-Type-Options "nosniff"
		Referrer-Policy "strict-origin-when-cross-origin"
		Content-Security-Policy "frame-ancestors 'self'"
	}
	reverse_proxy localhost:8080 {
		# SSE/streaming responses must not be buffered, or live updates stall behind the proxy.
		flush_interval -1
	}
}
